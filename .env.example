# Public runtime variables (safe for client bundle in Vite)
VITE_PUBLIC_SITE_URL="https://urmenroll.com"
VITE_ALLOWED_ORIGINS="https://urmenroll.com,https://www.urmenroll.com"
VITE_TURNSTILE_SITE_KEY="replace-with-turnstile-site-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="replace-with-turnstile-site-key"
VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_ENABLE_MIRROR_CATALOG="true"
VITE_ENABLE_MIRROR_FALLBACK="false"
VITE_INTERNAL_API_BASE_URL="http://127.0.0.1:3000"

# Calendly booking link for free consultation widget
# Find this in your Calendly dashboard → Event Types → Copy Link
VITE_CALENDLY_URL="https://calendly.com/your-username/free-consultation"

# Server-side runtime variables (MUST NOT be exposed to client)
URM_ALLOWED_ORIGINS="https://urmenroll.com,https://www.urmenroll.com"
SECURITY_ALLOWED_REDIRECTS="https://urmenroll.com,https://www.urmenroll.com"

# Contact API email transport
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="replace-with-smtp-username"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="noreply@urmenroll.com"
CONTACT_EMAIL="security-contact@urmenroll.com"

# Turnstile server verification secret (server-side only)
TURNSTILE_SECRET_KEY="replace-with-turnstile-secret-key"

# Optional Vercel KV REST credentials for distributed per-email limiting
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# Runtime mode
NODE_ENV="production"
DATABASE_URL="postgres://user:password@host:5432/enroll"

# -----------------------------------------------------------------------------
# URM Nexus integration (server-to-server only)
# -----------------------------------------------------------------------------
# Required in all environments
NEXUS_BASE_URL="http://127.0.0.1:3000"
NEXUS_INTEGRATION_API_KEY="replace-with-shared-nexus-integration-api-key"
ENROLL_SYNC_WORKER_SECRET="replace-with-unique-enroll-sync-worker-secret"

# Optional sync tuning
ENROLL_SYNC_PAGE_LIMIT="100"
ENROLL_SYNC_MAX_RETRIES="3"

# Local development examples
# NEXUS_BASE_URL="http://localhost:3000"
# NEXUS_INTEGRATION_API_KEY="nxs_lcl_your_local_shared_key"
# ENROLL_SYNC_WORKER_SECRET="enrwrk_lcl_your_local_worker_secret"

# Production examples
# NEXUS_BASE_URL="https://urmnexus.com"
# NEXUS_INTEGRATION_API_KEY="nxs_prd_your_production_shared_key"
# ENROLL_SYNC_WORKER_SECRET="enrwrk_prd_your_production_worker_secret"
